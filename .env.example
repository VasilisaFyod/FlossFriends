# Django settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database (SQL Server)
DB_ENGINE=mssql
DB_NAME=Floss_friends
DB_HOST=localhost\SQLEXPRESS
DB_USER=
DB_PASSWORD=

# Email (Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Pollinations (AI image generation)
POLLINATIONS_API_KEY=sk_xxx
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
POLLINATIONS_IMAGE_MODEL=flux
# Optional, OpenAI-compatible size, example: 1024x1024
# POLLINATIONS_IMAGE_SIZE=1024x1024
# Optional quality, example: standard or hd
# POLLINATIONS_IMAGE_QUALITY=standard
